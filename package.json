{
  "name": "taskroot",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && bun run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:start": "electron .",
    "start:offline": "node scripts/dev-runner.js --offline",
    "start:online": "node scripts/dev-runner.js",
    "test": "bun test --env=happy-dom"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible-next": "^5.3.0",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/ibm-plex-sans": "^5.3.0",
    "@xyflow/react": "^12.11.2",
    "cuelume": "^0.1.2",
    "firebase": "^11.2.0",
    "fuse.js": "^7.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.1.3",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.11.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
